{
  "name": "MkDocs Blog Devcontainer",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code"
      ],
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      }
    }
  },
  "forwardPorts": [8000],
  "postCreateCommand": "pip install --upgrade pip",
  "remoteUser": "root"
}
